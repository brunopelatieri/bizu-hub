# Postgres — Drizzle ORM (seu banco, server-only)
DATABASE_URL=postgresql://portal:portal@localhost:15432/portal
DIRECT_URL=postgresql://portal:portal@localhost:15432/portal

# Servidor único — React Router SSR + Hono API
PORT=3000

# Supabase — Auth + Storage (embutidos no bundle Vite no docker build)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Site em produção
# https://brunogoulart.com.br


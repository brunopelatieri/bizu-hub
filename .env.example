# ============================================================================
# Servidor único — React Router SSR + Hono API
# ============================================================================
PORT=3000
NODE_ENV=development

# ============================================================================
# Banco de Dados — Drizzle ORM + Postgres
# ============================================================================
# DATABASE_URL: usado em runtime (API)
# DIRECT_URL: usado por Drizzle Kit (migrations) — pode ser a mesma se não usar pooling
DATABASE_URL=postgresql://bizu_hub:bizu_hub@localhost:15432/bizu_hub
DIRECT_URL=postgresql://bizu_hub:bizu_hub@localhost:15432/bizu_hub

# ============================================================================
# Supabase — Auth, Storage, Edge Functions (auxiliar)
# ============================================================================
VITE_SUPABASE_URL=https://kpersdlqtrxlytwbuvvv.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_public_key_here

# ============================================================================
# Google Tag Manager (GTM) + Google Analytics 4 (GA4)
# ============================================================================
# GTM_ID: ID do container no Google Tag Manager (formato: GTM-XXXXXXX)
# Se vazio, GTM/GA4 são desabilitados
VITE_GTM_ID=GTM-XXXXXXX

# ============================================================================
# Pagamentos Stripe (futuro)
# ============================================================================
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
# STRIPE_SECRET_KEY=sk_test_xxxxx

# ============================================================================
# E-mails Transacionais (futuro)
# ============================================================================
# SMTP_HOST=smtp.seu-email.com
# SMTP_PORT=587
# SMTP_USER=seu-usuario
# SMTP_PASS=sua-senha
# MAIL_FROM=noreply@brunogoulart.com.br
